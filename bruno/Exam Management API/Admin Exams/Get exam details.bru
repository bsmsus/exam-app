meta {
  name: Get exam details
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/admin/exams/:examId
  body: none
  auth: bearer
}

params:path {
  examId: 
}

auth:bearer {
  token: {{token}}
}

example {
  name: 200 Response
  description: Exam details
  

                ],
                "summary": "Start a new exam attempt",
                "operationId": "a2b8ab25e40bcaf225a899da03e299ac",
                "parameters": [
                    {
                        "name": "examId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Attempt started",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "attemptId": {
                                            "type": "string",
                                            "format": "uuid"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized"
                    },
                    "404": {
                        "description": "Exam not found"
                    },
                    "409": {
                        "description": "Cannot start attempt (no attempts left, cooldown active, or attempt in progress)"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
